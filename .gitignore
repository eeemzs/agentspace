# ===================
# Tauri / Rust
# ===================

# Rust build output
src-tauri/target/
**/target/

# Cargo lock (optional - some prefer to track it)
# src-tauri/Cargo.lock

# Debug symbols
*.pdb
*.dSYM/

# Tauri generated files (schemas can be regenerated)
src-tauri/gen/

# Tauri bundle output
src-tauri/bundle/

# Tauri sidecar binaries (local builds)
src-tauri/binaries/

# Windows installer tools
src-tauri/WixTools/

# macOS app bundles during development
*.app/

# Linux AppImage/deb during development
*.AppImage
*.deb
*.rpm

# Windows installers
*.msi
*.exe
!src-tauri/binaries/*.exe

# Tauri sidecar binaries (if auto-generated)
# Keep tracked binaries in src-tauri/binaries/

# Rust incremental compilation
*.rmeta
*.rlib

# Rust analyzer
rust-project.json

# LLVM coverage
*.profraw
*.profdata

# Tauri CLI cache
.tauri/

# AOPS repo metadata should be tracked
!.aops/
