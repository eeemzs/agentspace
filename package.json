{
  "name": "@aopslab/agentspace-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source Agentspace domain workspace.",
  "workspaces": [
    "agentspace-cli",
    "agentspace-tooling",
    "agentspace-tests",
    "agentspace-dm",
    "agentspace-kit",
    "agentspace-core",
    "agentspace-ops",
    "agentspace-host-plugin"
  ],
  "scripts": {
    "bootstrap": "pnpm install",
    "changeset": "changeset",
    "db:generate": "bash ./scripts/db-generate.sh",
    "db:migrate": "bash ./scripts/db-migrate.sh",
    "db:push": "bash ./scripts/db-push.sh",
    "db:pull": "bash ./scripts/db-pull.sh",
    "build:tooling": "pnpm --filter @aopslab/domain-tooling-agentspace run build",
    "build:cli": "pnpm --filter @aopslab/domain-cli-agentspace run build",
    "build:core": "pnpm --filter @aopslab/domain-core-agentspace run build",
    "build:dm": "pnpm --filter @aopslab/domain-dm-agentspace run build",
    "build:kit": "pnpm --filter @aopslab/domain-kit-agentspace run build",
    "build:ops": "pnpm --filter @aopslab/domain-ops-agentspace run build",
    "build:host-plugin": "pnpm --filter @aopslab/domain-host-plugin-agentspace run build",
    "build:tests": "pnpm --filter @aopslab/domain-tests-agentspace run build",
    "build": "pnpm run build:core && pnpm run build:dm && pnpm run build:kit && pnpm run build:ops && pnpm run build:tooling && pnpm run build:host-plugin && pnpm run build:cli && pnpm run build:tests",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "test:integration": "pnpm --filter @aopslab/domain-tests-agentspace run test",
    "test": "pnpm run test:integration",
    "manifest:print": "pnpm --filter @aopslab/domain-cli-agentspace run start:tsx -- manifest all",
    "manifest:emit": "pnpm --filter @aopslab/domain-tooling-agentspace run manifest:emit && pnpm --filter @aopslab/domain-cli-agentspace run manifest:emit",
    "manifest:check": "pnpm --filter @aopslab/domain-tooling-agentspace run manifest:check && pnpm --filter @aopslab/domain-cli-agentspace run manifest:check",
    "manifest:sync": "pnpm run build:kit && pnpm run build:tooling && pnpm run build:host-plugin && pnpm run build:cli && pnpm run manifest:check",
    "smoke:cli": "node ./scripts/agentspace-cli-packed-smoke.mjs",
    "smoke:standalone": "node ./scripts/agentspace-standalone-smoke.mjs",
    "smoke:standalone:pg": "node ./scripts/agentspace-standalone-smoke.mjs --pg",
    "smoke:packed-install": "node ./scripts/agentspace-cli-packed-smoke.mjs",
    "release:status": "node ./scripts/changeset-status.mjs",
    "release:check": "node ./scripts/changeset-status.mjs",
    "release:version": "changeset version",
    "release:install": "pnpm install --frozen-lockfile",
    "release:build": "pnpm run build",
    "release:gate": "pnpm run manifest:sync && pnpm run smoke:packed-install -- --skip-build",
    "release:publish": "pnpm -r --filter './agentspace-*' --filter '!@aopslab/domain-tests-agentspace' publish --access public --registry https://registry.npmjs.org --no-git-checks",
    "ci": "pnpm run build && pnpm run typecheck && pnpm run test && pnpm run manifest:sync && pnpm run manifest:check",
    "version-packages": "changeset version"
  },
  "dependencies": {
    "@aopslab/xf-bm": "catalog:",
    "@aopslab/xf-core": "catalog:",
    "@aopslab/xf-db": "catalog:",
    "@aopslab/xf-db-drizzle": "catalog:",
    "@aopslab/xf-db-mongoose": "catalog:",
    "@aopslab/xf-db-redis": "catalog:",
    "@aopslab/xf-dm": "catalog:",
    "@aopslab/xf-dm-kits": "catalog:",
    "@aopslab/xf-i18n": "catalog:",
    "@aopslab/xf-logger": "catalog:",
    "@aopslab/xf-validation": "catalog:",
    "dotenv": "catalog:",
    "effect": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@types/node": "catalog:",
    "drizzle-kit": "catalog:",
    "drizzle-orm": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.9.0",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eeemzs/agentspace.git"
  }
}
