{
  "name": "@aopslab/domain-source-agentspace",
  "version": "0.0.1",
  "private": true,
  "description": "Agentspace domain workspace scaffold.",
  "workspaces": [
    "agentspace-cli",
    "agentspace-tooling",
    "agentspace-tests",
    "agentspace-dm",
    "agentspace-kit",
    "agentspace-core",
    "agentspace-ops",
    "agentspace-host-plugin"
  ],
  "scripts": {
    "bootstrap": "pnpm install",
    "changeset": "changeset",
    "db:generate": "bash ./scripts/db-generate.sh",
    "db:migrate": "bash ./scripts/db-migrate.sh",
    "db:push": "bash ./scripts/db-push.sh",
    "db:pull": "bash ./scripts/db-pull.sh",
    "build:tooling": "pnpm --filter @aopslab/domain-tooling-agentspace run build",
    "build:cli": "pnpm --filter @aopslab/domain-cli-agentspace run build",
    "build:core": "pnpm --filter @aopslab/domain-core-agentspace run build",
    "build:dm": "pnpm --filter @aopslab/domain-dm-agentspace run build",
    "build:kit": "pnpm --filter @aopslab/domain-kit-agentspace run build",
    "build:ops": "pnpm --filter @aopslab/domain-ops-agentspace run build",
    "build:host-plugin": "pnpm --filter @aopslab/domain-host-plugin-agentspace run build",
    "build:tests": "pnpm --filter @aopslab/domain-tests-agentspace run build",
    "build": "pnpm run build:core && pnpm run build:dm && pnpm run build:kit && pnpm run build:ops && pnpm run build:tooling && pnpm run build:cli && pnpm run build:host-plugin && pnpm run build:tests",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "test:integration": "pnpm --filter @aopslab/domain-tests-agentspace run test",
    "test": "pnpm run test:integration",
    "manifest:print": "pnpm --filter @aopslab/domain-cli-agentspace run start:tsx -- manifest all",
    "manifest:emit": "pnpm --filter @aopslab/domain-tooling-agentspace run manifest:emit && pnpm --filter @aopslab/domain-cli-agentspace run manifest:emit",
    "manifest:check": "pnpm --filter @aopslab/domain-tooling-agentspace run manifest:check && pnpm --filter @aopslab/domain-cli-agentspace run manifest:check",
    "manifest:sync": "pnpm run build:kit && pnpm run build:tooling && pnpm run build:host-plugin && pnpm run build:cli && pnpm run manifest:check",
    "registry:pull": "node ../registry-flow.mjs --mode pull --workspace .",
    "registry:publish": "node ../registry-flow.mjs --mode publish --workspace . --packages agentspace-core,agentspace-dm,agentspace-kit,agentspace-ops,agentspace-tooling,agentspace-cli,agentspace-host-plugin",
    "registry:full": "node ../registry-flow.mjs --mode full --workspace . --packages agentspace-core,agentspace-dm,agentspace-kit,agentspace-ops,agentspace-tooling,agentspace-cli,agentspace-host-plugin",
    "publish:core": "pnpm --filter @aopslab/domain-core-agentspace publish --access restricted --registry https://npm.pkg.github.com --no-git-checks",
    "publish:dm": "pnpm --filter @aopslab/domain-dm-agentspace publish --access restricted --registry https://npm.pkg.github.com --no-git-checks",
    "publish:kit": "pnpm --filter @aopslab/domain-kit-agentspace publish --access restricted --registry https://npm.pkg.github.com --no-git-checks",
    "publish:ops": "pnpm --filter @aopslab/domain-ops-agentspace publish --access restricted --registry https://npm.pkg.github.com --no-git-checks",
    "publish:tooling": "pnpm --filter @aopslab/domain-tooling-agentspace publish --access restricted --registry https://npm.pkg.github.com --no-git-checks",
    "publish:cli": "pnpm --filter @aopslab/domain-cli-agentspace publish --access restricted --registry https://npm.pkg.github.com --no-git-checks",
    "publish:host-plugin": "pnpm --filter @aopslab/domain-host-plugin-agentspace publish --access restricted --registry https://npm.pkg.github.com --no-git-checks",
    "publish:all": "pnpm run publish:core && pnpm run publish:dm && pnpm run publish:kit && pnpm run publish:ops && pnpm run publish:tooling && pnpm run publish:cli && pnpm run publish:host-plugin",
    "release:status": "node ./scripts/changeset-status.mjs",
    "release:check": "node ./scripts/changeset-status.mjs",
    "release:version": "changeset version",
    "release:install": "node ./scripts/with-gpr-token.mjs --scope aopslab -- pnpm install",
    "release:build": "pnpm -r --if-present run build",
    "release:gate": "pnpm run manifest:sync && pnpm run smoke:packed-install -- --skip-build",
    "smoke:cli": "node ./scripts/agentspace-cli-packed-smoke.mjs",
    "smoke:standalone": "node ./scripts/agentspace-standalone-smoke.mjs",
    "smoke:standalone:pg": "node ./scripts/agentspace-standalone-smoke.mjs --pg",
    "smoke:packed-install": "node ./scripts/agentspace-cli-packed-smoke.mjs",
    "smoke:private-registry": "node ./scripts/agentspace-cli-packed-smoke.mjs",
    "release:publish": "node ./scripts/with-gpr-token.mjs --scope aopslab -- pnpm -r publish --no-git-checks",
    "release": "pnpm run release:check && pnpm run release:version && pnpm run release:install && pnpm run release:build && pnpm run release:gate && pnpm run release:publish",
    "ci": "pnpm run build && pnpm run typecheck && pnpm run test && pnpm run manifest:sync && pnpm run manifest:check",
    "version-packages": "changeset version",
    "cascade:changeset": "node ./scripts/cascade-release.mjs",
    "cascade:release": "node ./scripts/cascade-release.mjs --release"
  },
  "dependencies": {
    "@aopslab/xf-bm": "catalog:",
    "@aopslab/xf-core": "catalog:",
    "@aopslab/xf-db": "catalog:",
    "@aopslab/xf-db-drizzle": "catalog:",
    "@aopslab/xf-db-mongoose": "catalog:",
    "@aopslab/xf-db-redis": "catalog:",
    "@aopslab/xf-dm": "catalog:",
    "@aopslab/xf-dm-kits": "catalog:",
    "@aopslab/xf-i18n": "catalog:",
    "@aopslab/xf-logger": "catalog:",
    "@aopslab/xf-validation": "catalog:",
    "dotenv": "catalog:",
    "effect": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@changesets/cli": "catalog:",
    "@types/node": "catalog:",
    "drizzle-kit": "catalog:",
    "drizzle-orm": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
