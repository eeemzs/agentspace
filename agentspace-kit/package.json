{
  "name": "@aopslab/domain-kit-agentspace",
  "version": "0.0.1",
  "type": "module",
  "description": "Agentspace kit surface.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b tsconfig.lib.json",
    "manifest:export": "node scripts/export-manifests.mjs",
    "manifest:build": "pnpm run build && pnpm run manifest:export"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "import": "./dist/errors/index.js",
      "default": "./dist/errors/index.js"
    },
    "./errors/i18n": {
      "types": "./dist/errors/i18n.d.ts",
      "import": "./dist/errors/i18n.js",
      "default": "./dist/errors/i18n.js"
    },
    "./shared": {
      "types": "./dist/shared/index.d.ts",
      "import": "./dist/shared/index.js",
      "default": "./dist/shared/index.js"
    },
    "./resources": {
      "types": "./dist/resources/index.d.ts",
      "import": "./dist/resources/index.js",
      "default": "./dist/resources/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "@aopslab/domain-dm-agentspace": "workspace:*",
    "@aopslab/xf-core": "catalog:",
    "@aopslab/xf-db": "catalog:",
    "@aopslab/xf-dm-kits": "catalog:",
    "@aopslab/xf-i18n": "catalog:",
    "@aopslab/xf-logger": "catalog:",
    "@aopslab/xf-validation": "catalog:",
    "dotenv": "catalog:",
    "effect": "catalog:",
    "zod": "catalog:"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "packageManager": "pnpm@10.0.0"
}
