{
  "name": "@aopslab/domain-host-plugin-agentspace",
  "version": "0.0.1",
  "type": "module",
  "private": false,
  "description": "Agentspace host plugin for xf-host compatible plugin registries.",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b tsconfig.lib.json"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "@aopslab/domain-kit-agentspace": "workspace:*",
    "ajv": "catalog:"
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "packageManager": "pnpm@10.0.0"
}
