{
  "name": "@aopslab/domain-host-plugin-agentspace",
  "version": "0.1.1",
  "type": "module",
  "private": false,
  "description": "Agentspace host plugin for xf-host compatible plugin registries.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eeemzs/agentspace.git",
    "directory": "agentspace-host-plugin"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b tsconfig.lib.json"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "NOTICE",
    "!**/*.tsbuildinfo"
  ],
  "dependencies": {
    "@aopslab/domain-kit-agentspace": "workspace:*",
    "@aopslab/xf-validation": "catalog:",
    "ajv": "catalog:"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "packageManager": "pnpm@10.0.0"
}
